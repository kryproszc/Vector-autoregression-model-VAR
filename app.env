# Single-file runtime configuration for local/dev.
# Keep secrets out of git in production.

# Environment mode: dev | test | prod
APP_ENV=dev

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002,http://localhost:3000,http://127.0.0.1:3000

# HTTPS enforcement at app level (behind reverse proxy set to 1 on prod)
ENFORCE_HTTPS=0

# Disable automatic startup seed for slownik_pozycje entries.
DISABLE_SLOWNIK_POZYCJE_SEED=1

# Disable automatic startup seed for default teams A/B/C/D.
DISABLE_TEAMS_SEED=1

# Team lead dictionary write restrictions.
# Allowlist (if set): manager can edit/add only these dictionary types.
# Requested scope:
# - ogolne: department_ogolne
# - inspekcje: nazwy_podmiotow, zakresy_inspekcji
# - wnioski sankcyjne: department, podstawa_prawna_sankcji,
#   naruszenia_skutkujace_sankcja, nazwy_podmiotow_sankcje
MANAGER_SLOWNIKI_ALLOWED_TYPES=department_ogolne,nazwy_podmiotow,zakresy_inspekcji,department,podstawa_prawna_sankcji,naruszenia_skutkujace_sankcja,nazwy_podmiotow_sankcje
# Types list format: kod_typu,kod_typu2
MANAGER_SLOWNIKI_BLOCKED_TYPES=
# Specific items format: kod_typu:kod_pozycji,kod_typu2:kod_pozycji2
MANAGER_SLOWNIKI_BLOCKED_ITEMS=

# Role-based blocking of inspection statuses for link-with-inspection views
# and save operations in modules: Zalecenia and Wnioski sankcyjne.
# Format: comma/semicolon/newline-separated status kod_pozycji values (e.g. I_SI_10,I_SI_11).
# Role IDs: 1=inspektor, 2=kierownik, 3=dyrektor.
# KOD POZYCJI SLOWNIKA: tutaj wpisujesz recznie kody statusow inspekcji do ukrycia/blokady.
RECOMMENDATIONS_BLOCKED_INSPECTION_STATUS_CODES=I_SI_15
RECOMMENDATIONS_BLOCKED_INSPECTION_STATUS_CODES_ROLE_1=I_SI_15
RECOMMENDATIONS_BLOCKED_INSPECTION_STATUS_CODES_ROLE_2=I_SI_15
RECOMMENDATIONS_BLOCKED_INSPECTION_STATUS_CODES_ROLE_3=I_SI_15

RISK_EXPOSURE_BLOCKED_INSPECTION_STATUS_CODES=
RISK_EXPOSURE_BLOCKED_INSPECTION_STATUS_CODES_ROLE_1=
RISK_EXPOSURE_BLOCKED_INSPECTION_STATUS_CODES_ROLE_2=
RISK_EXPOSURE_BLOCKED_INSPECTION_STATUS_CODES_ROLE_3=

# Decyzje zobowiazujace (powiazanie z zaleceniami):
# KOD POZYCJI SLOWNIKA statusu zalecenia (np. Z_SZ_1), dla ktorego
# nie pokazujemy opcji powiazania z zaleceniem i blokujemy zapis przez API.
OBLIGATING_DECISIONS_BLOCKED_RECOMMENDATION_STATUS_CODES=
OBLIGATING_DECISIONS_BLOCKED_RECOMMENDATION_STATUS_CODES_ROLE_1=
OBLIGATING_DECISIONS_BLOCKED_RECOMMENDATION_STATUS_CODES_ROLE_2=
OBLIGATING_DECISIONS_BLOCKED_RECOMMENDATION_STATUS_CODES_ROLE_3=

# Dashboard: wykluczenia po kodach statusow (kod_pozycji).
# Format: comma/semicolon/newline-separated values, np. I_SI_10,I_SI_11
# WYLACZENIA INSPEKCJI (statusy_inspekcji.kod_pozycji)
DASHBOARD_EXCLUDED_INSPECTION_STATUS_CODES=I_SI_15
# WYLACZENIA ZALECEN (statusy_zalecen.kod_pozycji)
DASHBOARD_EXCLUDED_RECOMMENDATION_STATUS_CODES=

# Raporty API (/api/reports/*): wykluczenia po kodach statusow (kod_pozycji).
# WYLACZENIA INSPEKCJI (statusy_inspekcji.kod_pozycji)
REPORTS_EXCLUDED_INSPECTION_STATUS_CODES=
# WYLACZENIA ZALECEN (statusy_zalecen.kod_pozycji)
REPORTS_EXCLUDED_RECOMMENDATION_STATUS_CODES=

# Auth session settings
AUTH_SESSION_TTL_HOURS=12
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_LOCKOUT_MINUTES=15

# Invite flow settings
AUTH_INVITE_TTL_HOURS=24
FRONTEND_INVITE_URL=http://localhost:3002/set-password
AUTH_PASSWORD_RESET_TTL_MINUTES=60
AUTH_PASSWORD_RESET_MIN_INTERVAL_SECONDS=60
FRONTEND_RESET_PASSWORD_URL=http://localhost:3002/reset-password

# Invite delivery mode: log | smtp
# - log: do not send email, return inviteLink in API response
# - smtp: send real email using SMTP settings below
INVITE_EMAIL_MODE=smtp

# SMTP settings (used only when INVITE_EMAIL_MODE=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_LOGIN=mateusz.winiarski.komm@gmail.com
SMTP_PASS=pevzemwdtgfoztcm
# Prefer storing SMTP password outside repo and pointing to it via SMTP_PASS_FILE.
SMTP_PASS_FILE=pevzemwdtgfoztcm
SMTP_LOGIN_MAIL=mateusz.winiarski.komm@gmail.com
FROM_EMAIL=mateusz.winiarski.komm@gmail.com
INVITE_EMAIL_SUBJECT=Zaproszenie do ustawienia hasla
INVITE_EMAIL_TEMPLATE_FILE=config/invite_email_template.txt
RESET_PASSWORD_EMAIL_SUBJECT=Reset hasla
RESET_PASSWORD_EMAIL_TEMPLATE_FILE=config/reset_password_email_template.txt

# When moving to internal/company SMTP, change only these fields:
# SMTP_HOST=
# SMTP_PORT=
# SMTP_SECURITY=starttls|ssl|plain
# SMTP_LOGIN=
# SMTP_PASS=
# SMTP_LOGIN_MAIL=
# FROM_EMAIL=
