# Automatic DB backup settings
# 1 = enabled, 0 = disabled
DB_BACKUP_ENABLED=1

# 1 = return 503 for API requests during backup window (except /health)
DB_BACKUP_BLOCK_REQUESTS=1

# Daily backup time in 24h format HH:MM (Europe/Warsaw)
DB_BACKUP_TIME=23:00

# Target directory for backup files.
# Relative path is resolved from backend root.
DB_BACKUP_DIR=Backups

# Backup filename format: <prefix>-YYYYMMDD-HHMMSS.db
DB_BACKUP_FILENAME_PREFIX=rejestr-backup

# Optional retention in days (0 = keep forever)
DB_BACKUP_KEEP_DAYS=30
