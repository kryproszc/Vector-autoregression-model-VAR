DROP TABLE IF EXISTS pokrycie_model;

CREATE TABLE pokrycie_model AS
SELECT
    v25.DATA_SPR,
    v25.TYP_OKRESU,
    v25.KOD_ZU,
    v25.C0010 AS wymog,
    v23.C0010 AS kdsw,
    v23.C0010 / NULLIF(v25.C0010, 0) AS kdsw_do_wymogu
FROM (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        MAX(C0010) AS C0010
    FROM V_S_25_05_01_01_DIU
    WHERE KOD_POZYCJI = 'R0030'
    GROUP BY
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU
) v25
LEFT JOIN (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        MAX(C0010) AS C0010
    FROM V_S_23_01_01_01_DIU
    WHERE KOD_POZYCJI = 'R0540'
    GROUP BY
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU
) v23
    ON v23.DATA_SPR = v25.DATA_SPR
   AND v23.TYP_OKRESU = v25.TYP_OKRESU
   AND v23.KOD_ZU = v25.KOD_ZU;
