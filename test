WITH baza AS (
    SELECT
        DATA_SPR,
        KOD_ZU,
        NAZWA_ZU,
        KOD_POZYCJI,
        COALESCE(C0130, C0131) AS wartosc,
        C0290
    FROM V_S_13_01_01_01_DIU
),

zaklady AS (
    SELECT DISTINCT
        DATA_SPR,
        KOD_ZU,
        NAZWA_ZU
    FROM baza
)

-- 1 część: C0130 / C0131
SELECT
    DATA_SPR,
    KOD_ZU,
    NAZWA_ZU,
    wartosc AS przyszle_koszty_rent,
    1 AS kolejnosc,
    KOD_POZYCJI
FROM baza

UNION ALL

-- 2 część: pięć zer
SELECT
    z.DATA_SPR,
    z.KOD_ZU,
    z.NAZWA_ZU,
    0 AS przyszle_koszty_rent,
    2 AS kolejnosc,
    v.n
FROM zaklady z
CROSS JOIN (
    SELECT 1 AS n UNION ALL
    SELECT 2 UNION ALL
    SELECT 3 UNION ALL
    SELECT 4 UNION ALL
    SELECT 5
) v

UNION ALL

-- 3 część: C0290
SELECT
    DATA_SPR,
    KOD_ZU,
    NAZWA_ZU,
    C0290,
    3 AS kolejnosc,
    KOD_POZYCJI
FROM baza

ORDER BY
    DATA_SPR,
    KOD_ZU,
    kolejnosc,
    KOD_POZYCJI
