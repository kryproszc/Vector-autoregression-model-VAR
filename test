DROP TABLE IF EXISTS duration_pasywow;

CREATE TABLE duration_pasywow AS
WITH base AS (

    SELECT
        DATA_SPR,
        KOD_ZU,
        tenor,
        pasywa_przeplywy,
        ROW_NUMBER() OVER(
            PARTITION BY DATA_SPR, KOD_ZU
            ORDER BY tenor DESC
        ) AS rn_desc
    FROM pasywa_przeplywy

),

normal_rows AS (

    SELECT
        DATA_SPR,
        KOD_ZU,
        pasywa_przeplywy
    FROM base
    WHERE rn_desc > 3

),

split_rows AS (

    SELECT
        b.DATA_SPR,
        b.KOD_ZU,
        b.pasywa_przeplywy / 10.0 AS pasywa_przeplywy
    FROM base b
    CROSS JOIN generate_series(1,10) g
    WHERE rn_desc <= 3

),

all_rows AS (

    SELECT * FROM normal_rows
    UNION ALL
    SELECT * FROM split_rows

)

SELECT
    DATA_SPR,
    KOD_ZU,
    pasywa_przeplywy,
    ROW_NUMBER() OVER(
        PARTITION BY DATA_SPR, KOD_ZU
        ORDER BY (SELECT NULL)
    ) AS tenor
FROM all_rows;
