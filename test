koszty_rent_suma AS (
    SELECT
        DATA_SPR,
        KOD_ZU,
        SUM(koszt_zdyskontowany) AS suma_kosztow_rent
    FROM koszty_rent_dyskonto
    GROUP BY
        DATA_SPR,
        KOD_ZU
),

r0240 AS (
    SELECT
        DATA_SPR,
        KOD_ZU,
        C0070
    FROM SNU_ANA.dbo.V_S_26_14_01_01_DIU
    WHERE KOD_POZYCJI = 'R0240'
),

wspolczynnik_rent AS (
    SELECT
        r.DATA_SPR,
        r.KOD_ZU,
        r.C0070,
        k.suma_kosztow_rent,
        r.C0070 / NULLIF(k.suma_kosztow_rent,0) AS wspolczynnik
    FROM r0240 r
    JOIN koszty_rent_suma k
        ON r.DATA_SPR = k.DATA_SPR
       AND r.KOD_ZU = k.KOD_ZU
)
