DROP TABLE IF EXISTS {target_table};

CREATE TABLE {target_table} AS
WITH base AS (
    SELECT
        {source_date_col}   AS DATA_SPR,
        {source_period_col} AS TYP_OKRESU,
        {source_entity_col} AS KOD_ZU,
        {series_col}        AS {series_col},
        CAST({value1_col} AS REAL) AS {value1_col},
        CAST({value2_col} AS REAL) AS {value2_col}
    FROM {source_table}
    {base_where_clause}
),
aggr AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        {series_col},
        SUM({value1_col}) AS {value1_col},
        SUM({value2_col}) AS {value2_col}
    FROM base
    GROUP BY
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        {series_col}
),
wynik_bazowy AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        {series_col},
        {value1_col},
        {value2_col},
        CASE
            WHEN {value2_col} IS NULL OR {value2_col} = 0 THEN NULL
            ELSE 1.0 * {value1_col} / {value2_col}
        END AS {ratio_col}
    FROM aggr
)
SELECT
    wb.DATA_SPR,
    wb.TYP_OKRESU,
    wb.KOD_ZU,
    wb.{series_col},
    wb.{value1_col},
    wb.{value2_col},
    wb.{ratio_col},

    (
        SELECT CASE
            WHEN wb.TYP_OKRESU = 'K'
             AND q.{ratio_col} IS NOT NULL
             AND q.{ratio_col} <> 0
            THEN 1.0 * wb.{ratio_col} / q.{ratio_col} - 1
        END
        FROM wynik_bazowy q
        WHERE q.KOD_ZU = wb.KOD_ZU
          AND q.{series_col} = wb.{series_col}
          AND q.TYP_OKRESU = 'K'
          AND wb.TYP_OKRESU = 'K'
          AND q.DATA_SPR = CASE
              WHEN strftime('%m-%d', wb.DATA_SPR) = '03-31'
                  THEN date(substr(wb.DATA_SPR, 1, 4) || '-01-01', '-1 day')
              WHEN strftime('%m-%d', wb.DATA_SPR) = '06-30'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-03-31'
              WHEN strftime('%m-%d', wb.DATA_SPR) = '09-30'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-06-30'
              WHEN strftime('%m-%d', wb.DATA_SPR) = '12-31'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-09-30'
          END
    ) AS {ratio_qoq_col},

    (
        SELECT CASE
            WHEN y.{ratio_col} IS NOT NULL
             AND y.{ratio_col} <> 0
            THEN 1.0 * wb.{ratio_col} / y.{ratio_col} - 1
        END
        FROM wynik_bazowy y
        WHERE y.KOD_ZU = wb.KOD_ZU
          AND y.{series_col} = wb.{series_col}
          AND y.TYP_OKRESU = wb.TYP_OKRESU
          AND y.DATA_SPR = date(wb.DATA_SPR, '-1 year')
    ) AS {ratio_yoy_col}

FROM wynik_bazowy wb;

