BEGIN TRANSACTION;

-- tworzymy nową strukturę bez Unnamed: 0
CREATE TABLE stopy_eiopa_tmp AS
SELECT
    "Unnamed: 0" AS tenor,
    YE2019,
    YE2020,
    YE2021,
    YE2022,
    YE2023,
    YE2024
FROM stopy_eiopa;

-- usuwamy starą tabelę
DROP TABLE stopy_eiopa;

-- zmieniamy nazwę nowej
ALTER TABLE stopy_eiopa_tmp
RENAME TO stopy_eiopa;

COMMIT;
