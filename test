from pathlib import Path
import sqlite3


BASE_DIR = Path(__file__).resolve().parent
DB_PATH = BASE_DIR.parent / "Bazalocal_snu_ana.db"
SQL_TEMPLATE_PATH = BASE_DIR / "template_stosunek_z_przyrostami.sql"


CONFIGS = {
    "stosunek_26_13_01_08_r0960": {
        "target_table": "stosunek_26_13_01_08_r0960",

        "source_table": "V_S_26_13_01_08_DIU",
        "source_date_col": "DATA_SPR",
        "source_period_col": "TYP_OKRESU",
        "source_entity_col": "KOD_ZU",

        "series_col": "Z0010",
        "value_col": "R0960",

        "base_where_clause": "",
    },
}


def validate_config(config: dict) -> None:
    required_fields = [
        "target_table",
        "source_table",
        "source_date_col",
        "source_period_col",
        "source_entity_col",
        "series_col",
        "value_col",
        "base_where_clause",
    ]

    missing = [field for field in required_fields if field not in config]
    if missing:
        raise ValueError(f"Brakuje pól w configu: {missing}")


def build_sql(config: dict) -> str:
    validate_config(config)

    template = SQL_TEMPLATE_PATH.read_text(encoding="utf-8")

    value_col = config["value_col"]
    share_col = f"udzial_{value_col}"
    share_qoq_col = f"{share_col}_kwartalnie"
    share_yoy_col = f"{share_col}_yoy"

    sql_params = {
        **config,
        "share_col": share_col,
        "share_qoq_col": share_qoq_col,
        "share_yoy_col": share_yoy_col,
    }

    return template.format(**sql_params)


def run_sql(db_path: Path, sql: str) -> None:
    conn = sqlite3.connect(db_path)
    try:
        cursor = conn.cursor()
        cursor.executescript(sql)
        conn.commit()
    finally:
        conn.close()


def run_case(case_name: str) -> None:
    if case_name not in CONFIGS:
        available = ", ".join(CONFIGS.keys())
        raise ValueError(f"Nieznany case: {case_name}. Dostępne: {available}")

    config = CONFIGS[case_name]
    sql = build_sql(config)

    print(f"Uruchamiam case: {case_name}")
    print(f"Tworzę tabelę: {config['target_table']}")
    run_sql(DB_PATH, sql)
    print("Gotowe.")


if __name__ == "__main__":
    run_case("stosunek_26_13_01_08_r0960")
