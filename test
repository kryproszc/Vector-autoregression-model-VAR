with kwartalne as (
    select
        DATA_SPR,
        KOD_ZU,
        wymog_do_aktywow,
        wymog_do_najlepszego_oszacowania_netto,

        lag(wymog_do_aktywow) over (
            partition by KOD_ZU
            order by DATA_SPR
        ) as prev_kw_aktywa,

        lag(wymog_do_najlepszego_oszacowania_netto) over (
            partition by KOD_ZU
            order by DATA_SPR
        ) as prev_kw_netto,

        lag(wymog_do_aktywow,4) over (
            partition by KOD_ZU
            order by DATA_SPR
        ) as prev_year_aktywa,

        lag(wymog_do_najlepszego_oszacowania_netto,4) over (
            partition by KOD_ZU
            order by DATA_SPR
        ) as prev_year_netto

    from calkowity_wymog_bez_przyrostow
    where TYP_OKRESU = 'K'
)

select
    t.DATA_SPR,
    t.TYP_OKRESU,
    t.KOD_ZU,
    t.wymog_do_aktywow,
    t.wymog_do_najlepszego_oszacowania_netto,

    case
        when t.TYP_OKRESU = 'K'
        then t.wymog_do_aktywow / k.prev_kw_aktywa - 1
    end as wymog_do_aktywow_kwartalnie,

    case
        when t.TYP_OKRESU = 'K'
        then t.wymog_do_najlepszego_oszacowania_netto / k.prev_kw_netto - 1
    end as wymog_do_najlepszego_oszacowania_netto_kwartalnie,

    case
        when t.TYP_OKRESU = 'K'
        then t.wymog_do_aktywow / k.prev_year_aktywa - 1
    end as wymog_do_aktywow_yoy,

    case
        when t.TYP_OKRESU = 'K'
        then t.wymog_do_najlepszego_oszacowania_netto / k.prev_year_netto - 1
    end as wymog_do_najlepszego_oszacowania_netto_yoy

from calkowity_wymog_bez_przyrostow t
left join kwartalne k
    on t.DATA_SPR = k.DATA_SPR
   and t.KOD_ZU = k.KOD_ZU

order by t.KOD_ZU, t.DATA_SPR;
