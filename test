DROP TABLE IF EXISTS {target_table};

CREATE TABLE {target_table} AS
WITH base AS (
    SELECT
        {source_date_col}   AS DATA_SPR,
        {source_period_col} AS TYP_OKRESU,
        {source_entity_col} AS KOD_ZU,
        {series_col}        AS SERIA,
        CAST({value_col} AS REAL) AS wartosc
    FROM {source_table}
    {base_where_clause}
),
wynik_bazowy AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        SERIA,
        wartosc,
        CASE
            WHEN SUM(wartosc) OVER (PARTITION BY DATA_SPR, TYP_OKRESU, KOD_ZU) = 0 THEN NULL
            ELSE wartosc * 1.0
                 / SUM(wartosc) OVER (PARTITION BY DATA_SPR, TYP_OKRESU, KOD_ZU)
        END AS stosunek
    FROM base
)
SELECT
    wb.DATA_SPR,
    wb.TYP_OKRESU,
    wb.KOD_ZU,
    wb.SERIA,
    wb.wartosc,
    wb.stosunek,

    (
        SELECT CASE
            WHEN wb.TYP_OKRESU = 'K'
             AND q.stosunek IS NOT NULL
             AND q.stosunek <> 0
            THEN 1.0 * wb.stosunek / q.stosunek - 1
        END
        FROM wynik_bazowy q
        WHERE q.KOD_ZU = wb.KOD_ZU
          AND q.SERIA = wb.SERIA
          AND q.TYP_OKRESU = 'K'
          AND wb.TYP_OKRESU = 'K'
          AND q.DATA_SPR = CASE
              WHEN strftime('%m-%d', wb.DATA_SPR) = '03-31'
                  THEN date(substr(wb.DATA_SPR, 1, 4) || '-01-01', '-1 day')
              WHEN strftime('%m-%d', wb.DATA_SPR) = '06-30'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-03-31'
              WHEN strftime('%m-%d', wb.DATA_SPR) = '09-30'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-06-30'
              WHEN strftime('%m-%d', wb.DATA_SPR) = '12-31'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-09-30'
          END
    ) AS stosunek_kwartalnie,

    (
        SELECT CASE
            WHEN y.stosunek IS NOT NULL
             AND y.stosunek <> 0
            THEN 1.0 * wb.stosunek / y.stosunek - 1
        END
        FROM wynik_bazowy y
        WHERE y.KOD_ZU = wb.KOD_ZU
          AND y.SERIA = wb.SERIA
          AND y.TYP_OKRESU = wb.TYP_OKRESU
          AND y.DATA_SPR = date(wb.DATA_SPR, '-1 year')
    ) AS stosunek_yoy

FROM wynik_bazowy wb;


