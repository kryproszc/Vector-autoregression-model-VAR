WITH baza AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        C0020,
        C0030,
        C0080,
        CASE
            WHEN C0030 = 106 THEN 0.0
            ELSE 1.0 * C0080
        END AS C0080_TEST
    FROM [SNU_ANA].[dbo].[V_S_26_15_01_02_DIU]
    WHERE C0080 IS NOT NULL
),
wartosci AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        COUNT(*) AS n,
        SUM(C0080_TEST) AS suma_c0080,
        SUM(C0080_TEST * C0080_TEST) AS suma_kwadratow_c0080
    FROM baza
    GROUP BY
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU
),
udzialy AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        C0020,
        C0030,
        C0080,
        C0080_TEST,
        1.0 * C0080_TEST / NULLIF(
            SUM(C0080_TEST) OVER (
                PARTITION BY DATA_SPR, TYP_OKRESU, KOD_ZU
            ), 0
        ) AS x_i
    FROM baza
),
srednie_udzialow AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        COUNT(*) AS n,
        AVG(x_i) AS srednia_x
    FROM udzialy
    GROUP BY
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU
),
odch AS (
    SELECT
        u.DATA_SPR,
        u.TYP_OKRESU,
        u.KOD_ZU,
        SQRT(
            SUM(POWER(u.x_i - s.srednia_x, 2)) * 1.0 / s.n
        ) AS odchylenie_standardowe_udzialow
    FROM udzialy u
    INNER JOIN srednie_udzialow s
        ON u.DATA_SPR = s.DATA_SPR
       AND u.TYP_OKRESU = s.TYP_OKRESU
       AND u.KOD_ZU = s.KOD_ZU
    GROUP BY
        u.DATA_SPR,
        u.TYP_OKRESU,
        u.KOD_ZU,
        s.n
),
pozycje_gini AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        x_i,
        ROW_NUMBER() OVER (
            PARTITION BY DATA_SPR, TYP_OKRESU, KOD_ZU
            ORDER BY x_i
        ) AS i,
        COUNT(*) OVER (
            PARTITION BY DATA_SPR, TYP_OKRESU, KOD_ZU
        ) AS n,
        SUM(x_i) OVER (
            PARTITION BY DATA_SPR, TYP_OKRESU, KOD_ZU
        ) AS suma_x
    FROM udzialy
),
gini AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        (
            2.0 * SUM(i * x_i) / NULLIF(MAX(n) * MAX(suma_x), 0)
        ) - (
            (MAX(n) + 1.0) / MAX(n)
        ) AS gini_udzialow
    FROM pozycje_gini
    GROUP BY
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU
)
SELECT
    w.DATA_SPR,
    w.TYP_OKRESU,
    w.KOD_ZU,
    w.n,
    w.suma_c0080,
    w.suma_kwadratow_c0080,
    o.odchylenie_standardowe_udzialow,
    g.gini_udzialow
FROM wartosci w
LEFT JOIN odch o
    ON w.DATA_SPR = o.DATA_SPR
   AND w.TYP_OKRESU = o.TYP_OKRESU
   AND w.KOD_ZU = o.KOD_ZU
LEFT JOIN gini g
    ON w.DATA_SPR = g.DATA_SPR
   AND w.TYP_OKRESU = g.TYP_OKRESU
   AND w.KOD_ZU = g.KOD_ZU
ORDER BY
    w.DATA_SPR,
    w.TYP_OKRESU,
    w.KOD_ZU;
