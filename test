const PALETTE_HUE_SAT: Record<StatusPalette, { hue: number; saturation: number }> = {
	slate: { hue: 215, saturation: 20 },
	gray: { hue: 215, saturation: 10 },
	zinc: { hue: 240, saturation: 6 },
	neutral: { hue: 30, saturation: 5 },
	stone: { hue: 24, saturation: 9 },
	red: { hue: 0, saturation: 84 },
	orange: { hue: 24, saturation: 92 },
	amber: { hue: 43, saturation: 96 },
	yellow: { hue: 55, saturation: 96 },
	lime: { hue: 83, saturation: 86 },
	green: { hue: 142, saturation: 71 },
	emerald: { hue: 160, saturation: 84 },
	teal: { hue: 173, saturation: 80 },
	cyan: { hue: 188, saturation: 94 },
	sky: { hue: 199, saturation: 95 },
	blue: { hue: 221, saturation: 83 },
	indigo: { hue: 239, saturation: 84 },
	violet: { hue: 258, saturation: 90 },
	purple: { hue: 270, saturation: 91 },
	fuchsia: { hue: 292, saturation: 84 },
	pink: { hue: 330, saturation: 81 },
	rose: { hue: 350, saturation: 89 },
};

const SHADE_TO_LIGHTNESS: Record<StatusShade, number> = {
	50: 97,
	100: 93,
	200: 86,
	300: 76,
	400: 65,
	500: 54,
	600: 45,
	700: 37,
	800: 30,
	900: 23,
	950: 14,
};

const PALETTE_LIGHTNESS_COMPENSATION: Partial<Record<StatusPalette, number>> = {
	yellow: -8,
	amber: -6,
	orange: -4,
	lime: -2,
	cyan: -1,
	sky: -1,
};

function resolvePerceptualLightness(palette: StatusPalette, lightness: number) {
	const compensation = PALETTE_LIGHTNESS_COMPENSATION[palette] ?? 0;
	return Math.max(8, Math.min(97, lightness + compensation));
}

function resolveStatusRowStyle(
	statusCode: string | undefined,
	config: StatusColorConfig,
	isHovered: boolean,
	hoverEffect: HoverEffectOption,
): CSSProperties {
	const normalized = (statusCode ?? "").trim().toUpperCase();
	const { si2, si3, si4, si5To9 } = config;

	const yellowStatusCodes = new Set([
		"I_SI_5",
		"I_SI_6",
		"I_SI_7",
		"I_SI_8",
		"I_SI_9",
	]);

	const getOpacity = (opacity: number) => Math.max(0, Math.min(opacity, 100)) / 100;

	const buildStatusBackground = (settings: ColorSettings) => {
		const palette = PALETTE_HUE_SAT[settings.color];
		const baseLightness = SHADE_TO_LIGHTNESS[settings.shade];
		const lightness = resolvePerceptualLightness(settings.color, baseLightness);
		const edgeOpacity = getOpacity(settings.opacity);
		const statusColor = `hsl(${palette.hue} ${palette.saturation}% ${lightness}% / ${edgeOpacity})`;
		const darkerEdgeLightness = Math.max(8, lightness - 16);
		const darkerOutlineColor = `hsl(${palette.hue} ${palette.saturation}% ${Math.max(8, lightness - 12)}% / ${Math.min(1, edgeOpacity + 0.12)})`;
		const edgeFrameColor = `hsl(${palette.hue} ${palette.saturation}% ${darkerEdgeLightness}% / ${Math.min(1, edgeOpacity + 0.24)})`;
		const strongBlurColor = `hsl(${palette.hue} ${palette.saturation}% ${darkerEdgeLightness}% / ${Math.min(1, edgeOpacity + 0.34)})`;

		const hoverShadow =
			hoverEffect === "softShadowBold"
				? `0 0 0 2px ${darkerOutlineColor}, 0 10px 22px -16px ${statusColor}`
				: hoverEffect === "strongEdgeShadow"
					? `inset 0 0 0 3px ${edgeFrameColor}, 0 18px 34px -14px ${strongBlurColor}`
					: hoverEffect === "smallBlurSelectedColor"
						? `0 0 0 2px ${darkerOutlineColor}, 0 6px 12px -10px ${statusColor}`
						: hoverEffect === "deepInnerBlur"
							? `inset 0 0 0 2px ${darkerOutlineColor}, inset 0 0 30px 8px ${statusColor}`
					: undefined;

		return {
			backgroundColor: statusColor,
			...(isHovered && hoverShadow
				? {
					boxShadow: hoverShadow,
				}
				: {}),
		};
	};

	if (normalized === "I_SI_2") {
		return buildStatusBackground(si2);
	}

	if (normalized === "I_SI_3") {
		return buildStatusBackground(si3);
	}

	if (normalized === "I_SI_4") {
		return buildStatusBackground(si4);
	}

	if (yellowStatusCodes.has(normalized)) {
		return buildStatusBackground(si5To9);
	}

	return {
		backgroundColor: "rgb(255 255 255 / 1)",
	};
}


