from __future__ import annotations

from pathlib import Path
import sqlite3
import sys

EXPECTED_PERMISSIONS: list[tuple[str, str, str, int]] = [
    ("registry.inspections.read", "Inspekcje", "rejestry", 1),
    ("registry.recommendations.read", "Zalecenia", "rejestry", 1),
    ("registry.obligating_decisions.read", "Decyzje zobowiazujace", "rejestry", 1),
    ("registry.risk_exposure.read", "Wnioski sankcyjne", "rejestry", 1),
    ("reports.executed_inspections.read", "Wykonane inspekcje", "raporty", 1),
    ("reports.protocol_time.read", "Czas protokolu", "raporty", 1),
    ("reports.report_time.read", "Czas sprawozdania", "raporty", 1),
]


def main() -> int:
    try:
        # Uzywa tej samej sciezki DB co backend
        from app.database.connection import DB_PATH
    except Exception as exc:
        print(f"ERR: nie mozna zaimportowac DB_PATH: {exc}")
        return 2

    db_path = Path(DB_PATH)
    print(f"DB_PATH: {db_path}")

    if not db_path.exists():
        print("ERR: plik bazy nie istnieje")
        return 3

    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    try:
        conn.execute("PRAGMA foreign_keys = ON")

        # Tabela powinna istniec, ale dla bezpieczenstwa:
        conn.execute(
            """
            CREATE TABLE IF NOT EXISTS auth_permissions (
                code TEXT PRIMARY KEY,
                label TEXT NOT NULL,
                permission_group TEXT NOT NULL,
                active INTEGER NOT NULL DEFAULT 1,
                created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
                updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
            )
            """
        )

        before = conn.execute("SELECT COUNT(*) AS c FROM auth_permissions").fetchone()["c"]
        print(f"auth_permissions before: {before}")

        conn.executemany(
            """
            INSERT OR IGNORE INTO auth_permissions (code, label, permission_group, active)
            VALUES (?, ?, ?, ?)
            """,
            EXPECTED_PERMISSIONS,
        )
        conn.commit()

        rows = conn.execute(
            "SELECT code, label, permission_group, active FROM auth_permissions ORDER BY code"
        ).fetchall()

        print(f"auth_permissions after: {len(rows)}")
        print("codes:")
        for r in rows:
            print(f"  {r['code']} | {r['label']} | {r['permission_group']} | active={r['active']}")

        existing_codes = {str(r["code"]) for r in rows}
        expected_codes = {code for code, _, _, _ in EXPECTED_PERMISSIONS}
        missing = sorted(expected_codes - existing_codes)

        if missing:
            print(f"ERR: nadal brakuje kodow: {missing}")
            return 4

        print("OK: auth_permissions uzupelnione. Mozesz ponowic dodawanie uzytkownika zewnetrznego.")
        return 0
    finally:
        conn.close()


if __name__ == "__main__":
    sys.exit(main())
