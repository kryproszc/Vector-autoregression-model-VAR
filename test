DROP TABLE IF EXISTS struktura_podmodulow;

CREATE TABLE struktura_podmodulow AS
SELECT
    rynk_i_kred.*,
    
    v0320.C0010 AS majatkowe,
    v0410.C0010 AS zyciowe,
    v0490.C0010 AS operacyjne,

    (
        COALESCE(rynk_i_kred.Rynkowe, 0) +
        COALESCE(rynk_i_kred.Kredytowe, 0) +
        COALESCE(v0320.C0010, 0) +
        COALESCE(v0410.C0010, 0) +
        COALESCE(v0490.C0010, 0)
    ) AS suma,

    CASE 
        WHEN (
            COALESCE(rynk_i_kred.Rynkowe, 0) +
            COALESCE(rynk_i_kred.Kredytowe, 0) +
            COALESCE(v0320.C0010, 0) +
            COALESCE(v0410.C0010, 0) +
            COALESCE(v0490.C0010, 0)
        ) = 0 THEN NULL
        ELSE COALESCE(rynk_i_kred.Rynkowe, 0) / (
            COALESCE(rynk_i_kred.Rynkowe, 0) +
            COALESCE(rynk_i_kred.Kredytowe, 0) +
            COALESCE(v0320.C0010, 0) +
            COALESCE(v0410.C0010, 0) +
            COALESCE(v0490.C0010, 0)
        )
    END AS udzial_rynkowe,

    CASE 
        WHEN (
            COALESCE(rynk_i_kred.Rynkowe, 0) +
            COALESCE(rynk_i_kred.Kredytowe, 0) +
            COALESCE(v0320.C0010, 0) +
            COALESCE(v0410.C0010, 0) +
            COALESCE(v0490.C0010, 0)
        ) = 0 THEN NULL
        ELSE COALESCE(rynk_i_kred.Kredytowe, 0) / (
            COALESCE(rynk_i_kred.Rynkowe, 0) +
            COALESCE(rynk_i_kred.Kredytowe, 0) +
            COALESCE(v0320.C0010, 0) +
            COALESCE(v0410.C0010, 0) +
            COALESCE(v0490.C0010, 0)
        )
    END AS udzial_kredytowe,

    CASE 
        WHEN (
            COALESCE(rynk_i_kred.Rynkowe, 0) +
            COALESCE(rynk_i_kred.Kredytowe, 0) +
            COALESCE(v0320.C0010, 0) +
            COALESCE(v0410.C0010, 0) +
            COALESCE(v0490.C0010, 0)
        ) = 0 THEN NULL
        ELSE COALESCE(v0320.C0010, 0) / (
            COALESCE(rynk_i_kred.Rynkowe, 0) +
            COALESCE(rynk_i_kred.Kredytowe, 0) +
            COALESCE(v0320.C0010, 0) +
            COALESCE(v0410.C0010, 0) +
            COALESCE(v0490.C0010, 0)
        )
    END AS udzial_majatkowe,

    CASE 
        WHEN (
            COALESCE(rynk_i_kred.Rynkowe, 0) +
            COALESCE(rynk_i_kred.Kredytowe, 0) +
            COALESCE(v0320.C0010, 0) +
            COALESCE(v0410.C0010, 0) +
            COALESCE(v0490.C0010, 0)
        ) = 0 THEN NULL
        ELSE COALESCE(v0410.C0010, 0) / (
            COALESCE(rynk_i_kred.Rynkowe, 0) +
            COALESCE(rynk_i_kred.Kredytowe, 0) +
            COALESCE(v0320.C0010, 0) +
            COALESCE(v0410.C0010, 0) +
            COALESCE(v0490.C0010, 0)
        )
    END AS udzial_zyciowe,

    CASE 
        WHEN (
            COALESCE(rynk_i_kred.Rynkowe, 0) +
            COALESCE(rynk_i_kred.Kredytowe, 0) +
            COALESCE(v0320.C0010, 0) +
            COALESCE(v0410.C0010, 0) +
            COALESCE(v0490.C0010, 0)
        ) = 0 THEN NULL
        ELSE COALESCE(v0490.C0010, 0) / (
            COALESCE(rynk_i_kred.Rynkowe, 0) +
            COALESCE(rynk_i_kred.Kredytowe, 0) +
            COALESCE(v0320.C0010, 0) +
            COALESCE(v0410.C0010, 0) +
            COALESCE(v0490.C0010, 0)
        )
    END AS udzial_operacyjne

FROM rynkowe_i_kredytowe rynk_i_kred

LEFT JOIN V_S_25_05_01_01_DIU v0320
    ON v0320.DATA_SPR = rynk_i_kred.DATA_SPR
   AND v0320.TYP_OKRESU = rynk_i_kred.TYP_OKRESU
   AND v0320.KOD_ZU = rynk_i_kred.KOD_ZU
   AND v0320.Kod_pozycji = 'R0320'

LEFT JOIN V_S_25_05_01_01_DIU v0410
    ON v0410.DATA_SPR = rynk_i_kred.DATA_SPR
   AND v0410.TYP_OKRESU = rynk_i_kred.TYP_OKRESU
   AND v0410.KOD_ZU = rynk_i_kred.KOD_ZU
   AND v0410.Kod_pozycji = 'R0410'

LEFT JOIN V_S_25_05_01_01_DIU v0490
    ON v0490.DATA_SPR = rynk_i_kred.DATA_SPR
   AND v0490.TYP_OKRESU = rynk_i_kred.TYP_OKRESU
   AND v0490.KOD_ZU = rynk_i_kred.KOD_ZU
   AND v0490.Kod_pozycji = 'R0490';


DROP TABLE IF EXISTS struktura_podmodulow_z_przyrostami;

CREATE TABLE struktura_podmodulow_z_przyrostami AS
SELECT
    t.*,

    CASE
        WHEN t.TYP_OKRESU = 'K'
         AND q.udzial_rynkowe IS NOT NULL
         AND q.udzial_rynkowe <> 0
        THEN t.udzial_rynkowe / q.udzial_rynkowe - 1
    END AS udzial_rynkowe_kwartalnie,

    CASE
        WHEN t.TYP_OKRESU = 'K'
         AND q.udzial_kredytowe IS NOT NULL
         AND q.udzial_kredytowe <> 0
        THEN t.udzial_kredytowe / q.udzial_kredytowe - 1
    END AS udzial_kredytowe_kwartalnie,

    CASE
        WHEN t.TYP_OKRESU = 'K'
         AND q.udzial_majatkowe IS NOT NULL
         AND q.udzial_majatkowe <> 0
        THEN t.udzial_majatkowe / q.udzial_majatkowe - 1
    END AS udzial_majatkowe_kwartalnie,

    CASE
        WHEN t.TYP_OKRESU = 'K'
         AND q.udzial_zyciowe IS NOT NULL
         AND q.udzial_zyciowe <> 0
        THEN t.udzial_zyciowe / q.udzial_zyciowe - 1
    END AS udzial_zyciowe_kwartalnie,

    CASE
        WHEN t.TYP_OKRESU = 'K'
         AND q.udzial_operacyjne IS NOT NULL
         AND q.udzial_operacyjne <> 0
        THEN t.udzial_operacyjne / q.udzial_operacyjne - 1
    END AS udzial_operacyjne_kwartalnie,

    CASE
        WHEN y.udzial_rynkowe IS NOT NULL
         AND y.udzial_rynkowe <> 0
        THEN t.udzial_rynkowe / y.udzial_rynkowe - 1
    END AS udzial_rynkowe_yoy,

    CASE
        WHEN y.udzial_kredytowe IS NOT NULL
         AND y.udzial_kredytowe <> 0
        THEN t.udzial_kredytowe / y.udzial_kredytowe - 1
    END AS udzial_kredytowe_yoy,

    CASE
        WHEN y.udzial_majatkowe IS NOT NULL
         AND y.udzial_majatkowe <> 0
        THEN t.udzial_majatkowe / y.udzial_majatkowe - 1
    END AS udzial_majatkowe_yoy,

    CASE
        WHEN y.udzial_zyciowe IS NOT NULL
         AND y.udzial_zyciowe <> 0
        THEN t.udzial_zyciowe / y.udzial_zyciowe - 1
    END AS udzial_zyciowe_yoy,

    CASE
        WHEN y.udzial_operacyjne IS NOT NULL
         AND y.udzial_operacyjne <> 0
        THEN t.udzial_operacyjne / y.udzial_operacyjne - 1
    END AS udzial_operacyjne_yoy

FROM struktura_podmodulow t

LEFT JOIN struktura_podmodulow q
    ON q.KOD_ZU = t.KOD_ZU
   AND q.TYP_OKRESU = 'K'
   AND t.TYP_OKRESU = 'K'
   AND q.DATA_SPR = CASE
       WHEN strftime('%m-%d', t.DATA_SPR) = '03-31'
           THEN date(substr(t.DATA_SPR, 1, 4) || '-01-01', '-1 day')
       WHEN strftime('%m-%d', t.DATA_SPR) = '06-30'
           THEN substr(t.DATA_SPR, 1, 4) || '-03-31'
       WHEN strftime('%m-%d', t.DATA_SPR) = '09-30'
           THEN substr(t.DATA_SPR, 1, 4) || '-06-30'
       WHEN strftime('%m-%d', t.DATA_SPR) = '12-31'
           THEN substr(t.DATA_SPR, 1, 4) || '-09-30'
   END

LEFT JOIN struktura_podmodulow y
    ON y.KOD_ZU = t.KOD_ZU
   AND y.TYP_OKRESU = t.TYP_OKRESU
   AND y.DATA_SPR = date(t.DATA_SPR, '-1 year');
