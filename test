DROP TABLE IF EXISTS dyw_calkowity_wymog;

CREATE TABLE dyw_calkowity_wymog AS
WITH base AS (
    SELECT
        v26.DATA_SPR,
        v26.TYP_OKRESU,
        v26.KOD_ZU,
        v26.KOD_POZYCJI,
        CAST(v26.C0020 AS REAL) AS wartosc
    FROM V_S_26_09_01_02_DIU v26
    WHERE v26.KOD_POZYCJI IN ('R0110', 'R0130', 'R0060', 'R0140')
),
rk AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        MAX(CAST(Rynkowe AS REAL)) AS Rynkowe
    FROM rynkowe_i_kredytowe
    GROUP BY
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU
),
aggr AS (
    SELECT
        b.DATA_SPR,
        b.TYP_OKRESU,
        b.KOD_ZU,
        COUNT(*) AS n,
        SUM(b.wartosc) AS suma_scr,
        SUM(b.wartosc * b.wartosc) AS suma_kwadratow
    FROM base b
    GROUP BY
        b.DATA_SPR,
        b.TYP_OKRESU,
        b.KOD_ZU
),
gini_base AS (
    SELECT
        b.DATA_SPR,
        b.TYP_OKRESU,
        b.KOD_ZU,
        b.wartosc,
        ROW_NUMBER() OVER (
            PARTITION BY b.DATA_SPR, b.TYP_OKRESU, b.KOD_ZU
            ORDER BY b.wartosc
        ) AS i
    FROM base b
),
gini_aggr AS (
    SELECT
        g.DATA_SPR,
        g.TYP_OKRESU,
        g.KOD_ZU,
        SUM(g.i * g.wartosc) AS suma_i_x
    FROM gini_base g
    GROUP BY
        g.DATA_SPR,
        g.TYP_OKRESU,
        g.KOD_ZU
),
udzialy AS (
    SELECT
        b.DATA_SPR,
        b.TYP_OKRESU,
        b.KOD_ZU,
        b.KOD_POZYCJI,
        b.wartosc,
        a.suma_scr,
        CASE
            WHEN a.suma_scr = 0 THEN NULL
            ELSE b.wartosc / a.suma_scr
        END AS udzial
    FROM base b
    JOIN aggr a
      ON b.DATA_SPR = a.DATA_SPR
     AND b.TYP_OKRESU = a.TYP_OKRESU
     AND b.KOD_ZU = a.KOD_ZU
),
udzialy_avg AS (
    SELECT
        u.DATA_SPR,
        u.TYP_OKRESU,
        u.KOD_ZU,
        COUNT(*) AS n_udzialow,
        AVG(u.udzial) AS srednia_udzialow
    FROM udzialy u
    GROUP BY
        u.DATA_SPR,
        u.TYP_OKRESU,
        u.KOD_ZU
),
stddev_pop_aggr AS (
    SELECT
        u.DATA_SPR,
        u.TYP_OKRESU,
        u.KOD_ZU,
        SQRT(
            SUM((u.udzial - ua.srednia_udzialow) * (u.udzial - ua.srednia_udzialow))
            / ua.n_udzialow
        ) AS odch_stand_pop
    FROM udzialy u
    JOIN udzialy_avg ua
      ON u.DATA_SPR = ua.DATA_SPR
     AND u.TYP_OKRESU = ua.TYP_OKRESU
     AND u.KOD_ZU = ua.KOD_ZU
    GROUP BY
        u.DATA_SPR,
        u.TYP_OKRESU,
        u.KOD_ZU
)
SELECT
    a.DATA_SPR,
    a.TYP_OKRESU,
    a.KOD_ZU,
    a.suma_scr,
    rk.Rynkowe,
    1 - (a.suma_scr - rk.Rynkowe) AS efekt_dywersyfikacji,
    CASE
        WHEN a.n = 0 OR a.suma_scr = 0 THEN NULL
        ELSE (2.0 * ga.suma_i_x) / (a.n * a.suma_scr) - ((a.n + 1.0) / a.n)
    END AS gini,
    CASE
        WHEN (a.suma_scr - SQRT(a.suma_kwadratow)) = 0 THEN NULL
        ELSE (a.suma_scr - rk.Rynkowe)
             / (a.suma_scr - SQRT(a.suma_kwadratow))
    END AS eiopa_diversification_score,
    sp.odch_stand_pop
FROM aggr a
LEFT JOIN rk
  ON a.DATA_SPR = rk.DATA_SPR
 AND a.TYP_OKRESU = rk.TYP_OKRESU
 AND a.KOD_ZU = rk.KOD_ZU
LEFT JOIN gini_aggr ga
  ON a.DATA_SPR = ga.DATA_SPR
 AND a.TYP_OKRESU = ga.TYP_OKRESU
 AND a.KOD_ZU = ga.KOD_ZU
LEFT JOIN stddev_pop_aggr sp
  ON a.DATA_SPR = sp.DATA_SPR
 AND a.TYP_OKRESU = sp.TYP_OKRESU
 AND a.KOD_ZU = sp.KOD_ZU;
