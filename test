DROP TABLE IF EXISTS dyskonto;

CREATE TABLE dyskonto AS

SELECT
    tenor,

    1.0 / POWER(1.0 + YE2019, tenor) AS YE2019,
    1.0 / POWER(1.0 + YE2020, tenor) AS YE2020,
    1.0 / POWER(1.0 + YE2021, tenor) AS YE2021,
    1.0 / POWER(1.0 + YE2022, tenor) AS YE2022,
    1.0 / POWER(1.0 + YE2023, tenor) AS YE2023,
    1.0 / POWER(1.0 + YE2024, tenor) AS YE2024

FROM stopy_eiopa;
