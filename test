DROP TABLE IF EXISTS pokrycie_fs;

CREATE TABLE pokrycie_fs AS
SELECT
    fs.DATA_SPR,
    fs.TYP_OKRESU,
    fs.KOD_ZU,

    MAX(CASE WHEN v23.KOD_POZYCJI = 'R0540' THEN v23.[C0010] END)
    / NULLIF(MAX(CASE WHEN fs.KOD_POZYCJI = 'R0200' THEN fs.[C0030] END), 0)
    AS kdsw_do_wymogu_fs,

    MAX(CASE WHEN v23.KOD_POZYCJI = 'R0540' THEN v23.[C0010] END)
    / NULLIF(
        MAX(CASE WHEN fs.KOD_POZYCJI = 'R0200' THEN fs.[C0030] END)
        - MAX(CASE WHEN fs.KOD_POZYCJI = 'R0150' THEN fs.[C0030] END),
        0
    )
    AS kdsw_do_wymogu_fs_pre_tax

FROM formula_standardowa fs
LEFT JOIN [SNU_ANA].[dbo].[V_S_23_01_01_01_DIU] v23
    ON v23.DATA_SPR = fs.DATA_SPR
   AND v23.TYP_OKRESU = fs.TYP_OKRESU
   AND v23.KOD_ZU = fs.KOD_ZU
GROUP BY
    fs.DATA_SPR,
    fs.TYP_OKRESU,
    fs.KOD_ZU;
