select
    t.DATA_SPR,
    t.TYP_OKRESU,
    t.KOD_ZU,
    t.wymog_do_aktywow,
    t.wymog_do_najlepszego_oszacowania_netto,

    case
        when t.TYP_OKRESU = 'K' and q.wymog_do_aktywow is not null
        then t.wymog_do_aktywow / q.wymog_do_aktywow - 1
    end as wymog_do_aktywow_kwartalnie,

    case
        when t.TYP_OKRESU = 'K' and q.wymog_do_najlepszego_oszacowania_netto is not null
        then t.wymog_do_najlepszego_oszacowania_netto / q.wymog_do_najlepszego_oszacowania_netto - 1
    end as wymog_do_najlepszego_oszacowania_netto_kwartalnie,

    case
        when y.wymog_do_aktywow is not null
        then t.wymog_do_aktywow / y.wymog_do_aktywow - 1
    end as wymog_do_aktywow_yoy,

    case
        when y.wymog_do_najlepszego_oszacowania_netto is not null
        then t.wymog_do_najlepszego_oszacowania_netto / y.wymog_do_najlepszego_oszacowania_netto - 1
    end as wymog_do_najlepszego_oszacowania_netto_yoy

from calkowity_wymog_bez_przyrostow t

left join calkowity_wymog_bez_przyrostow q
    on q.KOD_ZU = t.KOD_ZU
   and q.TYP_OKRESU = 'K'
   and t.TYP_OKRESU = 'K'
   and q.DATA_SPR = case
       when strftime('%m-%d', t.DATA_SPR) = '03-31'
           then date(substr(t.DATA_SPR, 1, 4) || '-01-01', '-1 day')
       when strftime('%m-%d', t.DATA_SPR) = '06-30'
           then substr(t.DATA_SPR, 1, 4) || '-03-31'
       when strftime('%m-%d', t.DATA_SPR) = '09-30'
           then substr(t.DATA_SPR, 1, 4) || '-06-30'
       when strftime('%m-%d', t.DATA_SPR) = '12-31'
           then substr(t.DATA_SPR, 1, 4) || '-09-30'
   end

left join calkowity_wymog_bez_przyrostow y
    on y.KOD_ZU = t.KOD_ZU
   and y.TYP_OKRESU = t.TYP_OKRESU
   and y.DATA_SPR = date(t.DATA_SPR, '-1 year')

order by t.KOD_ZU, t.DATA_SPR, t.TYP_OKRESU;
