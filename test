SELECT
    fs.DATA_SPR,
    fs.TYP_OKRESU,
    fs.KOD_ZU,

    MAX(CASE WHEN v23.KOD_POZYCJI = 'R0540' THEN v23.[C0010] ELSE 0 END) AS licznik,
    MAX(CASE WHEN fs.KOD_POZYCJI = 'R0200' THEN fs.[C0030] ELSE 0 END) AS r0200,
    MAX(CASE WHEN fs.KOD_POZYCJI = 'R0150' THEN fs.[C0030] ELSE 0 END) AS r0150,

    MAX(CASE WHEN fs.KOD_POZYCJI = 'R0200' THEN fs.[C0030] ELSE 0 END)
    - MAX(CASE WHEN fs.KOD_POZYCJI = 'R0150' THEN fs.[C0030] ELSE 0 END)
    AS mianownik_pre_tax,

    CAST(MAX(CASE WHEN v23.KOD_POZYCJI = 'R0540' THEN v23.[C0010] ELSE 0 END) AS DECIMAL(20,10))
    / NULLIF(CAST(MAX(CASE WHEN fs.KOD_POZYCJI = 'R0200' THEN fs.[C0030] ELSE 0 END) AS DECIMAL(20,10)), 0)
    AS kdsw_do_wymogu_fs,

    CAST(MAX(CASE WHEN v23.KOD_POZYCJI = 'R0540' THEN v23.[C0010] ELSE 0 END) AS DECIMAL(20,10))
    / NULLIF(
        CAST(
            MAX(CASE WHEN fs.KOD_POZYCJI = 'R0200' THEN fs.[C0030] ELSE 0 END)
            - MAX(CASE WHEN fs.KOD_POZYCJI = 'R0150' THEN fs.[C0030] ELSE 0 END)
            AS DECIMAL(20,10)
        ),
        0
    )
    AS kdsw_do_wymogu_fs_pre_tax
FROM formula_standardowa fs
LEFT JOIN [SNU_ANA].[dbo].[V_S_23_01_01_01_DIU] v23
    ON v23.DATA_SPR = fs.DATA_SPR
   AND v23.TYP_OKRESU = fs.TYP_OKRESU
   AND v23.KOD_ZU = fs.KOD_ZU
GROUP BY
    fs.DATA_SPR,
    fs.TYP_OKRESU,
    fs.KOD_ZU;
