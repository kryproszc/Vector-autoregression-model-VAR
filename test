SELECT
    [DATA_SPR],
    [TYP_OKRESU],
    [KOD_ZU],
    (
        SUM(CASE WHEN [KOD_POZYCJI] = 'R0030' THEN [C0010] ELSE 0 END)
        -
        SUM(CASE WHEN [KOD_POZYCJI] = 'R0040' THEN [C0010] ELSE 0 END)
    ) / NULLIF(
        SUM(CASE WHEN [KOD_POZYCJI] = 'R0030' THEN [C0010] ELSE 0 END),
        0
    ) AS WSKAZNIK
FROM [SNU_ANA].[dbo].[V_S_25_05_01_01_DIU]
WHERE [KOD_POZYCJI] IN ('R0030', 'R0040')
GROUP BY
    [DATA_SPR],
    [TYP_OKRESU],
    [KOD_ZU];
