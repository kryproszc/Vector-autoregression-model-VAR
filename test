DROP TABLE IF EXISTS {target_table};

CREATE TABLE {target_table} AS
WITH base AS (
    SELECT
        {source_date_col}   AS DATA_SPR,
        {source_period_col} AS TYP_OKRESU,
        {source_entity_col} AS KOD_ZU,
        {source_code_col}   AS KOD_POZYCJI,
        CAST({source_value_col} AS REAL) AS wartosc
    FROM {source_table}
    WHERE {source_code_col} IN ({source_codes_sql})
),
ref AS (
    SELECT
        {reference_date_col}   AS DATA_SPR,
        {reference_period_col} AS TYP_OKRESU,
        {reference_entity_col} AS KOD_ZU,
        MAX(CAST({reference_value_col} AS REAL)) AS wartosc_ref
    FROM {reference_table}
    {reference_where_clause}
    GROUP BY
        {reference_date_col},
        {reference_period_col},
        {reference_entity_col}
),
aggr AS (
    SELECT
        b.DATA_SPR,
        b.TYP_OKRESU,
        b.KOD_ZU,
        COUNT(*) AS n,
        SUM(b.wartosc) AS suma_scr,
        SUM(b.wartosc * b.wartosc) AS suma_kwadratow
    FROM base b
    GROUP BY
        b.DATA_SPR,
        b.TYP_OKRESU,
        b.KOD_ZU
),
gini_base AS (
    SELECT
        b.DATA_SPR,
        b.TYP_OKRESU,
        b.KOD_ZU,
        b.wartosc,
        ROW_NUMBER() OVER (
            PARTITION BY b.DATA_SPR, b.TYP_OKRESU, b.KOD_ZU
            ORDER BY b.wartosc
        ) AS i
    FROM base b
),
gini_aggr AS (
    SELECT
        g.DATA_SPR,
        g.TYP_OKRESU,
        g.KOD_ZU,
        SUM(g.i * g.wartosc) AS suma_i_x
    FROM gini_base g
    GROUP BY
        g.DATA_SPR,
        g.TYP_OKRESU,
        g.KOD_ZU
),
udzialy AS (
    SELECT
        b.DATA_SPR,
        b.TYP_OKRESU,
        b.KOD_ZU,
        b.KOD_POZYCJI,
        b.wartosc,
        a.suma_scr,
        CASE
            WHEN a.suma_scr = 0 THEN NULL
            ELSE b.wartosc / a.suma_scr
        END AS udzial
    FROM base b
    JOIN aggr a
      ON b.DATA_SPR = a.DATA_SPR
     AND b.TYP_OKRESU = a.TYP_OKRESU
     AND b.KOD_ZU = a.KOD_ZU
),
udzialy_avg AS (
    SELECT
        u.DATA_SPR,
        u.TYP_OKRESU,
        u.KOD_ZU,
        COUNT(*) AS n_udzialow,
        AVG(u.udzial) AS srednia_udzialow
    FROM udzialy u
    GROUP BY
        u.DATA_SPR,
        u.TYP_OKRESU,
        u.KOD_ZU
),
stddev_pop_aggr AS (
    SELECT
        u.DATA_SPR,
        u.TYP_OKRESU,
        u.KOD_ZU,
        SQRT(
            SUM((u.udzial - ua.srednia_udzialow) * (u.udzial - ua.srednia_udzialow))
            / ua.n_udzialow
        ) AS odch_stand_pop
    FROM udzialy u
    JOIN udzialy_avg ua
      ON u.DATA_SPR = ua.DATA_SPR
     AND u.TYP_OKRESU = ua.TYP_OKRESU
     AND u.KOD_ZU = ua.KOD_ZU
    GROUP BY
        u.DATA_SPR,
        u.TYP_OKRESU,
        u.KOD_ZU
),
wynik_bazowy AS (
    SELECT
        a.DATA_SPR,
        a.TYP_OKRESU,
        a.KOD_ZU,
        a.suma_scr,
        ref.wartosc_ref,
        1 - (a.suma_scr - ref.wartosc_ref) AS efekt_dywersyfikacji,
        CASE
            WHEN a.n = 0 OR a.suma_scr = 0 THEN NULL
            ELSE (2.0 * ga.suma_i_x) / (a.n * a.suma_scr) - ((a.n + 1.0) / a.n)
        END AS gini,
        CASE
            WHEN (a.suma_scr - SQRT(a.suma_kwadratow)) = 0 THEN NULL
            ELSE (a.suma_scr - ref.wartosc_ref)
                 / (a.suma_scr - SQRT(a.suma_kwadratow))
        END AS eiopa_diversification_score,
        sp.odch_stand_pop
    FROM aggr a
    LEFT JOIN ref
      ON a.DATA_SPR = ref.DATA_SPR
     AND a.TYP_OKRESU = ref.TYP_OKRESU
     AND a.KOD_ZU = ref.KOD_ZU
    LEFT JOIN gini_aggr ga
      ON a.DATA_SPR = ga.DATA_SPR
     AND a.TYP_OKRESU = ga.TYP_OKRESU
     AND a.KOD_ZU = ga.KOD_ZU
    LEFT JOIN stddev_pop_aggr sp
      ON a.DATA_SPR = sp.DATA_SPR
     AND a.TYP_OKRESU = sp.TYP_OKRESU
     AND a.KOD_ZU = sp.KOD_ZU
)
SELECT
    wb.DATA_SPR,
    wb.TYP_OKRESU,
    wb.KOD_ZU,
    wb.suma_scr,
    wb.wartosc_ref,
    wb.efekt_dywersyfikacji,
    wb.gini,
    wb.eiopa_diversification_score,
    wb.odch_stand_pop,

    (
        SELECT CASE
            WHEN wb.TYP_OKRESU = 'K'
             AND q.efekt_dywersyfikacji IS NOT NULL
             AND q.efekt_dywersyfikacji <> 0
            THEN 1.0 * wb.efekt_dywersyfikacji / q.efekt_dywersyfikacji - 1
        END
        FROM wynik_bazowy q
        WHERE q.KOD_ZU = wb.KOD_ZU
          AND q.TYP_OKRESU = 'K'
          AND wb.TYP_OKRESU = 'K'
          AND q.DATA_SPR = CASE
              WHEN strftime('%m-%d', wb.DATA_SPR) = '03-31'
                  THEN date(substr(wb.DATA_SPR, 1, 4) || '-01-01', '-1 day')
              WHEN strftime('%m-%d', wb.DATA_SPR) = '06-30'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-03-31'
              WHEN strftime('%m-%d', wb.DATA_SPR) = '09-30'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-06-30'
              WHEN strftime('%m-%d', wb.DATA_SPR) = '12-31'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-09-30'
          END
    ) AS efekt_dywersyfikacji_kwartalnie,

    (
        SELECT CASE
            WHEN y.efekt_dywersyfikacji IS NOT NULL
             AND y.efekt_dywersyfikacji <> 0
            THEN 1.0 * wb.efekt_dywersyfikacji / y.efekt_dywersyfikacji - 1
        END
        FROM wynik_bazowy y
        WHERE y.KOD_ZU = wb.KOD_ZU
          AND y.TYP_OKRESU = wb.TYP_OKRESU
          AND y.DATA_SPR = date(wb.DATA_SPR, '-1 year')
    ) AS efekt_dywersyfikacji_yoy,

    (
        SELECT CASE
            WHEN wb.TYP_OKRESU = 'K'
             AND q.gini IS NOT NULL
             AND q.gini <> 0
            THEN 1.0 * wb.gini / q.gini - 1
        END
        FROM wynik_bazowy q
        WHERE q.KOD_ZU = wb.KOD_ZU
          AND q.TYP_OKRESU = 'K'
          AND wb.TYP_OKRESU = 'K'
          AND q.DATA_SPR = CASE
              WHEN strftime('%m-%d', wb.DATA_SPR) = '03-31'
                  THEN date(substr(wb.DATA_SPR, 1, 4) || '-01-01', '-1 day')
              WHEN strftime('%m-%d', wb.DATA_SPR) = '06-30'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-03-31'
              WHEN strftime('%m-%d', wb.DATA_SPR) = '09-30'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-06-30'
              WHEN strftime('%m-%d', wb.DATA_SPR) = '12-31'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-09-30'
          END
    ) AS gini_kwartalnie,

    (
        SELECT CASE
            WHEN y.gini IS NOT NULL
             AND y.gini <> 0
            THEN 1.0 * wb.gini / y.gini - 1
        END
        FROM wynik_bazowy y
        WHERE y.KOD_ZU = wb.KOD_ZU
          AND y.TYP_OKRESU = wb.TYP_OKRESU
          AND y.DATA_SPR = date(wb.DATA_SPR, '-1 year')
    ) AS gini_yoy,

    (
        SELECT CASE
            WHEN wb.TYP_OKRESU = 'K'
             AND q.eiopa_diversification_score IS NOT NULL
             AND q.eiopa_diversification_score <> 0
            THEN 1.0 * wb.eiopa_diversification_score / q.eiopa_diversification_score - 1
        END
        FROM wynik_bazowy q
        WHERE q.KOD_ZU = wb.KOD_ZU
          AND q.TYP_OKRESU = 'K'
          AND wb.TYP_OKRESU = 'K'
          AND q.DATA_SPR = CASE
              WHEN strftime('%m-%d', wb.DATA_SPR) = '03-31'
                  THEN date(substr(wb.DATA_SPR, 1, 4) || '-01-01', '-1 day')
              WHEN strftime('%m-%d', wb.DATA_SPR) = '06-30'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-03-31'
              WHEN strftime('%m-%d', wb.DATA_SPR) = '09-30'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-06-30'
              WHEN strftime('%m-%d', wb.DATA_SPR) = '12-31'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-09-30'
          END
    ) AS eiopa_diversification_score_kwartalnie,

    (
        SELECT CASE
            WHEN y.eiopa_diversification_score IS NOT NULL
             AND y.eiopa_diversification_score <> 0
            THEN 1.0 * wb.eiopa_diversification_score / y.eiopa_diversification_score - 1
        END
        FROM wynik_bazowy y
        WHERE y.KOD_ZU = wb.KOD_ZU
          AND y.TYP_OKRESU = wb.TYP_OKRESU
          AND y.DATA_SPR = date(wb.DATA_SPR, '-1 year')
    ) AS eiopa_diversification_score_yoy,

    (
        SELECT CASE
            WHEN wb.TYP_OKRESU = 'K'
             AND q.odch_stand_pop IS NOT NULL
             AND q.odch_stand_pop <> 0
            THEN 1.0 * wb.odch_stand_pop / q.odch_stand_pop - 1
        END
        FROM wynik_bazowy q
        WHERE q.KOD_ZU = wb.KOD_ZU
          AND q.TYP_OKRESU = 'K'
          AND wb.TYP_OKRESU = 'K'
          AND q.DATA_SPR = CASE
              WHEN strftime('%m-%d', wb.DATA_SPR) = '03-31'
                  THEN date(substr(wb.DATA_SPR, 1, 4) || '-01-01', '-1 day')
              WHEN strftime('%m-%d', wb.DATA_SPR) = '06-30'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-03-31'
              WHEN strftime('%m-%d', wb.DATA_SPR) = '09-30'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-06-30'
              WHEN strftime('%m-%d', wb.DATA_SPR) = '12-31'
                  THEN substr(wb.DATA_SPR, 1, 4) || '-09-30'
          END
    ) AS odch_stand_pop_kwartalnie,

    (
        SELECT CASE
            WHEN y.odch_stand_pop IS NOT NULL
             AND y.odch_stand_pop <> 0
            THEN 1.0 * wb.odch_stand_pop / y.odch_stand_pop - 1
        END
        FROM wynik_bazowy y
        WHERE y.KOD_ZU = wb.KOD_ZU
          AND y.TYP_OKRESU = wb.TYP_OKRESU
          AND y.DATA_SPR = date(wb.DATA_SPR, '-1 year')
    ) AS odch_stand_pop_yoy

FROM wynik_bazowy wb;
