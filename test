def quote_sql_value(value: str) -> str:
    """Bezpieczne opakowanie stringa do SQL."""
    escaped = value.replace("'", "''")
    return f"'{escaped}'"


def build_source_codes_sql(source_codes: list[str]) -> str:
    if not source_codes:
        raise ValueError("Lista source_codes nie może być pusta.")
    return ", ".join(quote_sql_value(code) for code in source_codes)


def build_reference_where_clause(config: dict) -> str:
    reference_code = config.get("reference_code")
    reference_code_col = config.get("reference_code_col")

    if reference_code is None or reference_code == "":
        return ""

    if not reference_code_col:
        raise ValueError("Podano reference_code, ale brak reference_code_col.")

    return f"WHERE {reference_code_col} = {quote_sql_value(reference_code)}"


def validate_config(config: dict) -> None:
    required_fields = [
        "target_table",
        "source_table",
        "source_value_col",
        "source_code_col",
        "source_codes",
        "source_date_col",
        "source_period_col",
        "source_entity_col",
        "reference_table",
        "reference_value_col",
        "reference_date_col",
        "reference_period_col",
        "reference_entity_col",
    ]

    missing = [field for field in required_fields if field not in config]
    if missing:
        raise ValueError(f"Brakuje pól w configu: {missing}")

    if not isinstance(config["source_codes"], list) or not config["source_codes"]:
        raise ValueError("source_codes musi być niepustą listą.")


def build_sql(config: dict) -> str:
    validate_config(config)

    template = SQL_TEMPLATE_PATH.read_text(encoding="utf-8")

    sql_params = {
        **config,
        "source_codes_sql": build_source_codes_sql(config["source_codes"]),
        "reference_where_clause": build_reference_where_clause(config),
    }

    return template.format(**sql_params)


def run_sql(db_path: Path, sql: str) -> None:
    conn = sqlite3.connect(db_path)
    try:
        cursor = conn.cursor()
        cursor.executescript(sql)
        conn.commit()
    finally:
        conn.close()


def run_case(case_name: str) -> None:
    if case_name not in CONFIGS:
        available = ", ".join(CONFIGS.keys())
        raise ValueError(f"Nieznany case: {case_name}. Dostępne: {available}")

    config = CONFIGS[case_name]
    sql = build_sql(config)

    print(f"Uruchamiam case: {case_name}")
    print(f"Tworzę tabelę: {config['target_table']}")
    run_sql(DB_PATH, sql)
    print("Gotowe.")


