SELECT
    DATA_SPR,
    KOD_ZU,
    Z0010,
    R0960,
    SUM(R0960) OVER (PARTITION BY DATA_SPR, KOD_ZU) AS suma_r0960,
    CASE 
        WHEN SUM(R0960) OVER (PARTITION BY DATA_SPR, KOD_ZU) = 0 THEN NULL
        ELSE R0960 * 1.0 / SUM(R0960) OVER (PARTITION BY DATA_SPR, KOD_ZU)
    END AS stosunek
FROM [SNU_ANA].[dbo].[V_S_26_13_01_08_DIU]
