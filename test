WITH baza AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        C0020,
        C0030,
        C0080
    FROM [SNU_ANA].[dbo].[V_S_26_15_01_02_DIU]
    WHERE C0030 <> 106
),
udzialy AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        C0020,
        C0030,
        C0080,
        1.0 * C0080 / NULLIF(
            SUM(C0080) OVER (
                PARTITION BY DATA_SPR, TYP_OKRESU, KOD_ZU
            ), 0
        ) AS x_i
    FROM baza
)
SELECT *
FROM udzialy;
