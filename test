WITH numbers AS (
    SELECT 1 n UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 UNION ALL SELECT 5
    UNION ALL SELECT 6 UNION ALL SELECT 7 UNION ALL SELECT 8 UNION ALL SELECT 9 UNION ALL SELECT 10
),

tmp_pasywa_split AS (

    WITH base AS (
        SELECT
            DATA_SPR,
            KOD_ZU,
            tenor,
            pasywa_przeplywy,
            ROW_NUMBER() OVER(
                PARTITION BY DATA_SPR, KOD_ZU
                ORDER BY tenor DESC
            ) AS rn_desc
        FROM pasywa_przeplywy
    ),

    normal_rows AS (
        SELECT
            DATA_SPR,
            KOD_ZU,
            pasywa_przeplywy
        FROM base
        WHERE rn_desc > 3
    ),

    split_rows AS (
        SELECT
            b.DATA_SPR,
            b.KOD_ZU,
            b.pasywa_przeplywy / 10.0 AS pasywa_przeplywy
        FROM base b
        CROSS JOIN numbers
        WHERE rn_desc <= 3
    ),

    all_rows AS (
        SELECT * FROM normal_rows
        UNION ALL
        SELECT * FROM split_rows
    )

    SELECT
        DATA_SPR,
        KOD_ZU,
        pasywa_przeplywy,
        ROW_NUMBER() OVER(
            PARTITION BY DATA_SPR, KOD_ZU
            ORDER BY (SELECT NULL)
        ) AS tenor
    FROM all_rows
)

INSERT INTO duration_pasywow (DATA_SPR, KOD_ZU, tenor, pasywa_przeplywy)
SELECT
    DATA_SPR,
    KOD_ZU,
    tenor,
    pasywa_przeplywy
FROM tmp_pasywa_split;
