WITH v25_baza AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,

        SUM(CASE WHEN KOD_POZYCJI = 'R0020' THEN C0010 ELSE 0 END) AS r0020,
        SUM(CASE WHEN KOD_POZYCJI = 'R0030' THEN C0010 ELSE 0 END) AS r0030,
        SUM(CASE WHEN KOD_POZYCJI = 'R0040' THEN C0010 ELSE 0 END) AS r0040,
        SUM(CASE WHEN KOD_POZYCJI = 'R0080' THEN C0010 ELSE 0 END) AS r0080,
        SUM(CASE WHEN KOD_POZYCJI = 'R0200' THEN C0010 ELSE 0 END) AS r0200,
        SUM(CASE WHEN KOD_POZYCJI = 'R0320' THEN C0010 ELSE 0 END) AS r0320,
        SUM(CASE WHEN KOD_POZYCJI = 'R0400' THEN C0010 ELSE 0 END) AS r0400,
        SUM(CASE WHEN KOD_POZYCJI = 'R0410' THEN C0010 ELSE 0 END) AS r0410,
        SUM(CASE WHEN KOD_POZYCJI = 'R0490' THEN C0010 ELSE 0 END) AS r0490
    FROM V_S_25_05_01_01_DIU
    WHERE KOD_ZU IN (16, 21)
    GROUP BY
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU
),
v26_baza AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        SUM(CASE WHEN KOD_POZYCJI = 'R0800' THEN C0080 ELSE 0 END) AS r0800,
        SUM(CASE WHEN KOD_POZYCJI = 'R0900' THEN C0080 ELSE 0 END) AS r0900
    FROM V_S_26_03_01_04_DIU
    WHERE KOD_ZU IN (16, 21)
    GROUP BY
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU
),
rk_baza AS (
    SELECT
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU,
        SUM(COALESCE(Rynkowe, 0)) AS rynkowe,
        SUM(COALESCE(Kredytowe, 0)) AS kredytowe
    FROM rynkowe_i_kredytowe_dodatkowe_wyniki
    WHERE KOD_ZU IN (16, 21)
    GROUP BY
        DATA_SPR,
        TYP_OKRESU,
        KOD_ZU
)
SELECT
    v25.DATA_SPR,
    v25.TYP_OKRESU,
    v25.KOD_ZU,

    v25.r0020,
    v25.r0030,
    v25.r0040,
    v25.r0080,
    v25.r0200,
    v25.r0320,
    v25.r0400,
    v25.r0410,
    v25.r0490,

    COALESCE(v26.r0800, 0) AS r0800,
    COALESCE(v26.r0900, 0) AS r0900,

    COALESCE(rk.rynkowe, 0) AS rynkowe,
    COALESCE(rk.kredytowe, 0) AS kredytowe

FROM v25_baza v25
LEFT JOIN v26_baza v26
    ON v25.DATA_SPR = v26.DATA_SPR
   AND v25.TYP_OKRESU = v26.TYP_OKRESU
   AND v25.KOD_ZU = v26.KOD_ZU
LEFT JOIN rk_baza rk
    ON v25.DATA_SPR = rk.DATA_SPR
   AND v25.TYP_OKRESU = rk.TYP_OKRESU
   AND v25.KOD_ZU = rk.KOD_ZU
ORDER BY
    v25.KOD_ZU,
    v25.DATA_SPR,
    v25.TYP_OKRESU;
