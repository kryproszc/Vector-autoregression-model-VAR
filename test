select
    t.DATA_SPR,
    t.TYP_OKRESU,
    t.KOD_ZU,
    t.KOD_POZYCJI,

    t.wymog_do_naj_oszac_maj,
    t.wymog_do_skladki_zar_net,
    t.wymog_skladki_naj_oszac_rez_skl,
    t.wymog_rezerw_naj_oszac_rez_na_niewyplacone,

    -- kwartalnie
    case
        when t.TYP_OKRESU = 'K' and q.wymog_do_naj_oszac_maj is not null
        then t.wymog_do_naj_oszac_maj / q.wymog_do_naj_oszac_maj - 1
    end as wymog_do_naj_oszac_maj_kwartalnie,

    case
        when t.TYP_OKRESU = 'K' and q.wymog_do_skladki_zar_net is not null
        then t.wymog_do_skladki_zar_net / q.wymog_do_skladki_zar_net - 1
    end as wymog_do_skladki_zar_net_kwartalnie,

    case
        when t.TYP_OKRESU = 'K' and q.wymog_skladki_naj_oszac_rez_skl is not null
        then t.wymog_skladki_naj_oszac_rez_skl / q.wymog_skladki_naj_oszac_rez_skl - 1
    end as wymog_skladki_naj_oszac_rez_skl_kwartalnie,

    case
        when t.TYP_OKRESU = 'K' and q.wymog_rezerw_naj_oszac_rez_na_niewyplacone is not null
        then t.wymog_rezerw_naj_oszac_rez_na_niewyplacone / q.wymog_rezerw_naj_oszac_rez_na_niewyplacone - 1
    end as wymog_rezerw_naj_oszac_rez_na_niewyplacone_kwartalnie,

    -- rok do roku
    case
        when y.wymog_do_naj_oszac_maj is not null
        then t.wymog_do_naj_oszac_maj / y.wymog_do_naj_oszac_maj - 1
    end as wymog_do_naj_oszac_maj_yoy,

    case
        when y.wymog_do_skladki_zar_net is not null
        then t.wymog_do_skladki_zar_net / y.wymog_do_skladki_zar_net - 1
    end as wymog_do_skladki_zar_net_yoy,

    case
        when y.wymog_skladki_naj_oszac_rez_skl is not null
        then t.wymog_skladki_naj_oszac_rez_skl / y.wymog_skladki_naj_oszac_rez_skl - 1
    end as wymog_skladki_naj_oszac_rez_skl_yoy,

    case
        when y.wymog_rezerw_naj_oszac_rez_na_niewyplacone is not null
        then t.wymog_rezerw_naj_oszac_rez_na_niewyplacone / y.wymog_rezerw_naj_oszac_rez_na_niewyplacone - 1
    end as wymog_rezerw_naj_oszac_rez_na_niewyplacone_yoy

from ryzyko_majatkowe_bez_przyrostow t

left join ryzyko_majatkowe_bez_przyrostow q
    on q.KOD_ZU = t.KOD_ZU
   and q.TYP_OKRESU = 'K'
   and t.TYP_OKRESU = 'K'
   and q.DATA_SPR = case
       when strftime('%m-%d', t.DATA_SPR) = '03-31'
           then date(substr(t.DATA_SPR, 1, 4) || '-01-01', '-1 day')
       when strftime('%m-%d', t.DATA_SPR) = '06-30'
           then substr(t.DATA_SPR, 1, 4) || '-03-31'
       when strftime('%m-%d', t.DATA_SPR) = '09-30'
           then substr(t.DATA_SPR, 1, 4) || '-06-30'
       when strftime('%m-%d', t.DATA_SPR) = '12-31'
           then substr(t.DATA_SPR, 1, 4) || '-09-30'
   end

left join ryzyko_majatkowe_bez_przyrostow y
    on y.KOD_ZU = t.KOD_ZU
   and y.TYP_OKRESU = t.TYP_OKRESU
   and y.DATA_SPR = date(t.DATA_SPR, '-1 year')

order by t.KOD_ZU, t.DATA_SPR, t.TYP_OKRESU;
