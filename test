DROP TABLE IF EXISTS dyskonto;

CREATE TABLE dyskonto AS

SELECT
    '2019-12-31' AS DATA_SPR,
    ROW_NUMBER() OVER (ORDER BY tenor) AS tenor,
    1.0 / POWER(1.0 + YE2019, tenor) AS dyskonto
FROM stopy_eiopa

UNION ALL

SELECT
    '2020-12-31',
    ROW_NUMBER() OVER (ORDER BY tenor),
    1.0 / POWER(1.0 + YE2020, tenor)
FROM stopy_eiopa

UNION ALL

SELECT
    '2021-12-31',
    ROW_NUMBER() OVER (ORDER BY tenor),
    1.0 / POWER(1.0 + YE2021, tenor)
FROM stopy_eiopa

UNION ALL

SELECT
    '2022-12-31',
    ROW_NUMBER() OVER (ORDER BY tenor),
    1.0 / POWER(1.0 + YE2022, tenor)
FROM stopy_eiopa

UNION ALL

SELECT
    '2023-12-31',
    ROW_NUMBER() OVER (ORDER BY tenor),
    1.0 / POWER(1.0 + YE2023, tenor)
FROM stopy_eiopa

UNION ALL

SELECT
    '2024-12-31',
    ROW_NUMBER() OVER (ORDER BY tenor),
    1.0 / POWER(1.0 + YE2024, tenor)
FROM stopy_eiopa;
