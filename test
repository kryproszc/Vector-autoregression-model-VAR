with kwartalne as (
    select
        DATA_SPR,
        KOD_ZU,
        wymog_do_aktywow,
        wymog_do_najlepszego_oszacowania_netto,

        lag(wymog_do_aktywow) over (
            partition by KOD_ZU
            order by DATA_SPR
        ) as prev_kw_aktywa,

        lag(wymog_do_najlepszego_oszacowania_netto) over (
            partition by KOD_ZU
            order by DATA_SPR
        ) as prev_kw_netto

    from calkowity_wymog_bez_przyrostow
    where TYP_OKRESU = 'K'
),

rok_do_roku as (
    select
        DATA_SPR,
        KOD_ZU,
        TYP_OKRESU,
        wymog_do_aktywow,
        wymog_do_najlepszego_oszacowania_netto,

        lag(wymog_do_aktywow) over (
            partition by KOD_ZU, TYP_OKRESU
            order by DATA_SPR
        ) as prev_year_aktywa,

        lag(wymog_do_najlepszego_oszacowania_netto) over (
            partition by KOD_ZU, TYP_OKRESU
            order by DATA_SPR
        ) as prev_year_netto

    from calkowity_wymog_bez_przyrostow
)

select
    t.DATA_SPR,
    t.TYP_OKRESU,
    t.KOD_ZU,
    t.wymog_do_aktywow,
    t.wymog_do_najlepszego_oszacowania_netto,

    case
        when t.TYP_OKRESU = 'K'
        then t.wymog_do_aktywow / k.prev_kw_aktywa - 1
    end as wymog_do_aktywow_kwartalnie,

    case
        when t.TYP_OKRESU = 'K'
        then t.wymog_do_najlepszego_oszacowania_netto / k.prev_kw_netto - 1
    end as wymog_do_najlepszego_oszacowania_netto_kwartalnie,

    t.wymog_do_aktywow / r.prev_year_aktywa - 1
        as wymog_do_aktywow_yoy,

    t.wymog_do_najlepszego_oszacowania_netto / r.prev_year_netto - 1
        as wymog_do_najlepszego_oszacowania_netto_yoy

from calkowity_wymog_bez_przyrostow t

left join kwartalne k
    on t.DATA_SPR = k.DATA_SPR
   and t.KOD_ZU = k.KOD_ZU

left join rok_do_roku r
    on t.DATA_SPR = r.DATA_SPR
   and t.KOD_ZU = r.KOD_ZU
   and t.TYP_OKRESU = r.TYP_OKRESU

order by t.KOD_ZU, t.DATA_SPR;
