SELECT
v26.DATA_SPR,
v26.KOD_ZU,
v26.KOD_POZYCJI,
v26.C0020,

CASE 
    WHEN v26.KOD_POZYCJI = 'R0110'
    THEN v26.C0020 * 1.0 / NULLIF(s02_sum.SUMA_WSK1,0)
END AS WSK_R0110,

CASE 
    WHEN v26.KOD_POZYCJI = 'R0190'
    THEN v26.C0020 * 1.0 / NULLIF(s02_sum.SUMA_WSK2,0)
END AS WSK_R0190,

CASE 
    WHEN v26.KOD_POZYCJI = 'R0180'
    THEN v26.C0020 * 1.0 / NULLIF(s02_sum.SUMA_WSK3,0)
END AS WSK_R0180

FROM [SNU_ANA].[dbo].[V_S_26_09_01_02_DIU] v26

LEFT JOIN s02_sum
ON v26.DATA_SPR = s02_sum.DATA_SPR
AND v26.KOD_ZU = s02_sum.KOD_ZU
