DROP TABLE IF EXISTS strScr_na_zycie;

CREATE TABLE strScr_na_zycie AS
SELECT
    rynk_i_kred.*,
    v0060.C0070 AS Dlugowiecznosc,
    v0250.C0070 AS Wydatki,

    COALESCE(v0060.C0070, 0) + COALESCE(v0250.C0070, 0) AS suma,

    CASE
        WHEN COALESCE(v0060.C0070, 0) + COALESCE(v0250.C0070, 0) = 0 THEN NULL
        ELSE COALESCE(v0060.C0070, 0) * 1.0
             / (COALESCE(v0060.C0070, 0) + COALESCE(v0250.C0070, 0))
    END AS udzial_dlugowiecznosci,

    CASE
        WHEN COALESCE(v0060.C0070, 0) + COALESCE(v0250.C0070, 0) = 0 THEN NULL
        ELSE COALESCE(v0250.C0070, 0) * 1.0
             / (COALESCE(v0060.C0070, 0) + COALESCE(v0250.C0070, 0))
    END AS udzial_wydatki

FROM rynkowe_i_kredytowe rynk_i_kred

LEFT JOIN V_S_26_14_01_01_DIU v0060
    ON v0060.DATA_SPR = rynk_i_kred.DATA_SPR
   AND v0060.TYP_OKRESU = rynk_i_kred.TYP_OKRESU
   AND v0060.KOD_ZU = rynk_i_kred.KOD_ZU
   AND v0060.KOD_POZYCJI = 'R0060'

LEFT JOIN V_S_26_14_01_01_DIU v0250
    ON v0250.DATA_SPR = rynk_i_kred.DATA_SPR
   AND v0250.TYP_OKRESU = rynk_i_kred.TYP_OKRESU
   AND v0250.KOD_ZU = rynk_i_kred.KOD_ZU
   AND v0250.KOD_POZYCJI = 'R0250';


ALTER TABLE strScr_na_zycie ADD COLUMN udzial_dlugowiecznosci_kwartalnie REAL;
ALTER TABLE strScr_na_zycie ADD COLUMN udzial_wydatki_kwartalnie REAL;
ALTER TABLE strScr_na_zycie ADD COLUMN udzial_dlugowiecznosci_yoy REAL;
ALTER TABLE strScr_na_zycie ADD COLUMN udzial_wydatki_yoy REAL;


UPDATE strScr_na_zycie AS t
SET
    udzial_dlugowiecznosci_kwartalnie = (
        SELECT CASE
            WHEN t.TYP_OKRESU = 'K'
             AND q.udzial_dlugowiecznosci IS NOT NULL
             AND q.udzial_dlugowiecznosci <> 0
            THEN 1.0 * t.udzial_dlugowiecznosci / q.udzial_dlugowiecznosci - 1
        END
        FROM strScr_na_zycie q
        WHERE q.KOD_ZU = t.KOD_ZU
          AND q.TYP_OKRESU = 'K'
          AND t.TYP_OKRESU = 'K'
          AND q.DATA_SPR = CASE
              WHEN strftime('%m-%d', t.DATA_SPR) = '03-31'
                  THEN date(substr(t.DATA_SPR, 1, 4) || '-01-01', '-1 day')
              WHEN strftime('%m-%d', t.DATA_SPR) = '06-30'
                  THEN substr(t.DATA_SPR, 1, 4) || '-03-31'
              WHEN strftime('%m-%d', t.DATA_SPR) = '09-30'
                  THEN substr(t.DATA_SPR, 1, 4) || '-06-30'
              WHEN strftime('%m-%d', t.DATA_SPR) = '12-31'
                  THEN substr(t.DATA_SPR, 1, 4) || '-09-30'
          END
    ),

    udzial_wydatki_kwartalnie = (
        SELECT CASE
            WHEN t.TYP_OKRESU = 'K'
             AND q.udzial_wydatki IS NOT NULL
             AND q.udzial_wydatki <> 0
            THEN 1.0 * t.udzial_wydatki / q.udzial_wydatki - 1
        END
        FROM strScr_na_zycie q
        WHERE q.KOD_ZU = t.KOD_ZU
          AND q.TYP_OKRESU = 'K'
          AND t.TYP_OKRESU = 'K'
          AND q.DATA_SPR = CASE
              WHEN strftime('%m-%d', t.DATA_SPR) = '03-31'
                  THEN date(substr(t.DATA_SPR, 1, 4) || '-01-01', '-1 day')
              WHEN strftime('%m-%d', t.DATA_SPR) = '06-30'
                  THEN substr(t.DATA_SPR, 1, 4) || '-03-31'
              WHEN strftime('%m-%d', t.DATA_SPR) = '09-30'
                  THEN substr(t.DATA_SPR, 1, 4) || '-06-30'
              WHEN strftime('%m-%d', t.DATA_SPR) = '12-31'
                  THEN substr(t.DATA_SPR, 1, 4) || '-09-30'
          END
    ),

    udzial_dlugowiecznosci_yoy = (
        SELECT CASE
            WHEN y.udzial_dlugowiecznosci IS NOT NULL
             AND y.udzial_dlugowiecznosci <> 0
            THEN 1.0 * t.udzial_dlugowiecznosci / y.udzial_dlugowiecznosci - 1
        END
        FROM strScr_na_zycie y
        WHERE y.KOD_ZU = t.KOD_ZU
          AND y.TYP_OKRESU = t.TYP_OKRESU
          AND y.DATA_SPR = date(t.DATA_SPR, '-1 year')
    ),

    udzial_wydatki_yoy = (
        SELECT CASE
            WHEN y.udzial_wydatki IS NOT NULL
             AND y.udzial_wydatki <> 0
            THEN 1.0 * t.udzial_wydatki / y.udzial_wydatki - 1
        END
        FROM strScr_na_zycie y
        WHERE y.KOD_ZU = t.KOD_ZU
          AND y.TYP_OKRESU = t.TYP_OKRESU
          AND y.DATA_SPR = date(t.DATA_SPR, '-1 year')
    );
