DROP TABLE IF EXISTS struktura_podmodulow;

CREATE TABLE struktura_podmodulow AS
SELECT
    rynk_i_kred.*,
    MAX(CASE WHEN v25.Kod_pozycji = 'R0320' THEN v25.wartosc END) AS NonLife,
    MAX(CASE WHEN v25.Kod_pozycji = 'R0410' THEN v25.wartosc END) AS Life,
    MAX(CASE WHEN v25.Kod_pozycji = 'R0490' THEN v25.wartosc END) AS Operation
FROM rynkowe_i_kredytowe rynk_i_kred
LEFT JOIN V_S_25_05_01_01_DIU v25
    ON v25.DATA_SPR = rynk_i_kred.DATA_SPR
   AND v25.TYP_OKRESU = rynk_i_kred.TYP_OKRESU
   AND v25.KOD_ZU = rynk_i_kred.KOD_ZU
GROUP BY
    rynk_i_kred.*;
