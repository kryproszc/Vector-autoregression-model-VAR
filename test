	const resolvedYearCountRows = useMemo(() => {
		if (yearCountByTeamRows.length > 0) {
			return yearCountByTeamRows
				.filter((row) => row.inspekcja === inspectionType)
				.map((row) => ({
				label: row.zespol,
				values: row.values,
				}));
		}

		return yearCountRows.map((row) => ({
			label: row.label.split(" - ")[0]?.trim() || row.label,
			values: row.values,
