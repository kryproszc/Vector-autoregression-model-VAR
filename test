WITH s02_sum AS (
    SELECT
        COALESCE(a.DATA_SPR, b.DATA_SPR) AS DATA_SPR,
        COALESCE(a.KOD_ZU, b.KOD_ZU) AS KOD_ZU,
        COALESCE(a.TYP_OKRESU, b.TYP_OKRESU) AS TYP_OKRESU,

        SUM(CASE
            WHEN COALESCE(a.KOD_POZYCJI, b.KOD_POZYCJI) IN ('R0130','R0200','R0230','R0270','R0350','R0360','R0370','R0380')
            THEN COALESCE(a.C0010, b.C0010)
        END) AS SUMA_WSK1,

        SUM(CASE
            WHEN COALESCE(a.KOD_POZYCJI, b.KOD_POZYCJI) IN ('R0130','R0200')
            THEN COALESCE(a.C0010, b.C0010)
        END) AS SUMA_WSK2,

        SUM(CASE
            WHEN COALESCE(a.KOD_POZYCJI, b.KOD_POZYCJI) IN ('R0270')
            THEN COALESCE(a.C0010, b.C0010)
        END) AS SUMA_WSK3,

        SUM(CASE
            WHEN COALESCE(a.KOD_POZYCJI, b.KOD_POZYCJI) IN ('R0230')
            THEN COALESCE(a.C0010, b.C0010)
        END) AS SUMA_WSK4,

        SUM(CASE
            WHEN COALESCE(a.KOD_POZYCJI, b.KOD_POZYCJI) IN ('R0360','R0370','R0380')
            THEN COALESCE(a.C0010, b.C0010)
        END) AS SUMA_WSK5

    FROM SNU_ANA.dbo.V_S_02_01_01_01_DIU a
    FULL OUTER JOIN SNU_ANA.dbo.V_S_02_01_02_01_DIU b
        ON a.DATA_SPR = b.DATA_SPR
       AND a.KOD_ZU = b.KOD_ZU
       AND a.TYP_OKRESU = b.TYP_OKRESU
       AND a.KOD_POZYCJI = b.KOD_POZYCJI

    GROUP BY
        COALESCE(a.DATA_SPR, b.DATA_SPR),
        COALESCE(a.KOD_ZU, b.KOD_ZU),
        COALESCE(a.TYP_OKRESU, b.TYP_OKRESU)
)
