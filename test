CONFIGS = {
    "stosunek_26_13_01_08_r0960": {
        "target_table": "stosunek_26_13_01_08_r0960",

        "source_table": "V_S_26_13_01_08_DIU",
        "source_date_col": "DATA_SPR",
        "source_period_col": "TYP_OKRESU",
        "source_entity_col": "KOD_ZU",

        "series_col": "Z0010",
        "value_col": "R0960",

        # jeśli nie chcesz żadnego filtra, zostaw pusty string
