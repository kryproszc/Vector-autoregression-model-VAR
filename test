WITH irr_table AS (
    SELECT
        b.DATA_SPR,
        b.KOD_ZU,
        b.tenor,
        b.pasywa_przeplywy,
        b.dyskonto,
        b.CFv,
        b.CFv_do_t,
        CASE
            WHEN b.tenor = 1 THEN irr_calc.irr
        END AS irr
    FROM base_irr b
    LEFT JOIN irr_calc
        ON b.DATA_SPR = irr_calc.DATA_SPR
       AND b.KOD_ZU = irr_calc.KOD_ZU
)


SELECT
    DATA_SPR,
    KOD_ZU,

    SUM(CFv) AS suma_CFv,
    SUM(CFv_do_t) AS suma_CFv_do_t,

    MAX(irr) AS irr,

    SUM(CFv_do_t) / SUM(CFv) /
    (1 + MAX(irr)) AS duration_aktywow

FROM irr_table

GROUP BY
    DATA_SPR,
    KOD_ZU;
