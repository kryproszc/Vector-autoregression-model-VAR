SELECT
    tps.DATA_SPR,
    tps.KOD_ZU,
    tps.tenor,
    tps.pasywa_przeplywy,
    dysk.dyskonto,

    tps.pasywa_przeplywy * dysk.dyskonto AS CFv_dyskonto,

    tps.pasywa_przeplywy * POWER(dysk.dyskonto, tps.tenor) AS CFv_dyskonto_tenor

FROM tmp_pasywa_split tps

LEFT JOIN dyskonto dysk
    ON tps.DATA_SPR = dysk.DATA_SPR
    AND tps.tenor = dysk.tenor
;
