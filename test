import pyodbc
from sqlalchemy import create_engine, inspect

# ====================================
# DANE POŁĄCZENIA
# ====================================
SERVER = "dtc-newmf-snu"
DATABASE = "SNU_ANA"
USERNAME = "TWOJ_LOGIN"
PASSWORD = "TWOJE_HASLO"

# ====================================
# WYBÓR STEROWNIKA ODBC
# ====================================
# Najpierw sprawdzamy, jakie sterowniki są dostępne
drivers = pyodbc.drivers()
print("Dostępne sterowniki ODBC:")
for d in drivers:
    print(" -", d)

# Preferowany driver
if "ODBC Driver 17 for SQL Server" in drivers:
    DRIVER = "ODBC Driver 17 for SQL Server"
elif "ODBC Driver 18 for SQL Server" in drivers:
    DRIVER = "ODBC Driver 18 for SQL Server"
elif "SQL Server" in drivers:
    DRIVER = "SQL Server"
else:
    raise Exception("Brak sterownika do SQL Server. Zainstaluj ODBC Driver.")

print("\nUżywany driver:", DRIVER)

# ====================================
# CONNECTION STRING
# ====================================
connection_string = (
    f"mssql+pyodbc://{USERNAME}:{PASSWORD}@{SERVER}/{DATABASE}"
    f"?driver={DRIVER.replace(' ', '+')}"
)

# ====================================
# POŁĄCZENIE I ODCZYT OBIEKTÓW
# ====================================
try:
    engine = create_engine(connection_string)
    inspector = inspect(engine)

    print("\nPołączenie OK")

    print("\n=== TABELE ===")
    tables = inspector.get_table_names()
    if tables:
        for table in tables:
            print(table)
    else:
        print("Brak tabel albo brak uprawnień.")

    print("\n=== WIDOKI ===")
    views = inspector.get_view_names()
    if views:
        for view in views:
            print(view)
    else:
        print("Brak widoków albo brak uprawnień.")

except Exception as e:
    print("\nBŁĄD:")
    print(e)
