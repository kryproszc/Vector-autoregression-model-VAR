DROP TABLE IF EXISTS koszty_zdyskontowane;

CREATE TABLE koszty_zdyskontowane AS

SELECT
    p.DATA_SPR,
    p.KOD_ZU,
    p.NAZWA_ZU,
    p.tenor,
    p.przyszle_koszty_rent,
    d.dyskonto,
    p.przyszle_koszty_rent * d.dyskonto AS koszt_zdyskontowany
FROM przyszle_koszty_rent p
JOIN dyskonto d
    ON p.DATA_SPR = d.DATA_SPR
   AND p.tenor = d.tenor
ORDER BY
    p.DATA_SPR,
    p.KOD_ZU,
    p.tenor;
