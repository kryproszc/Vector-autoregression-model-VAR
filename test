SELECT
    YEAR(t1.DATA_SPR) AS ROK,
    t1.KOD_ZU,
    SUM(t1.c0170 * ISNULL(t2.C0360,0)) AS SUMA_C0360_C0170
INTO duration_aktywa_licznik
FROM [V_S_06_02_01_01_DIU] t1
LEFT JOIN [SNU_ANA].[dbo].[V_S_06_02_01_02_DIU] t2
    ON t1.C0040_2 = t2.C0040_2
    AND t1.DATA_SPR = t2.DATA_SPR
    AND t1.KOD_ZU = t2.KOD_ZU
WHERE SUBSTRING(CAST(t1.DATA_SPR AS varchar(10)),6,2) = '12'
GROUP BY
    YEAR(t1.DATA_SPR),
    t1.KOD_ZU
